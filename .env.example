# LLM brain — use OpenRouter (free) and/or Gemini. AMITY_LLM_PROVIDER: auto | openrouter | gemini
AMITY_LLM_PROVIDER=auto
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Voice — API fallback + agent-worker TTS (use the same ELEVENLABS_VOICE_ID in both paths)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Beyond Presence — lip-sync via LiveKit Agents (see docs/RECOVERY_AVATAR.md)
BEYOND_PRESENCE_API_KEY=
BEYOND_PRESENCE_AGENT_ID=
# false = LiveKit lip-sync (recommended). true = full bey.chat iframe (separate BP agent).
BEYOND_PRESENCE_EMBED_IFRAME=false
BEYOND_PRESENCE_AVATAR_ID=

# LiveKit Cloud — required for lip-sync; run: npm run agent:dev
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Bey avatar for agent worker (defaults to BEYOND_PRESENCE_AVATAR_ID)
BEY_AVATAR_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
