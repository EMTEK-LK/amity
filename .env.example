# =============================================================================
# Amity — environment template (copy to .env.local)
# See docs/LLM_AND_RECOVERY_PIPELINE.md and README.md
# =============================================================================

# --- LLM (coaching brain) ---
# auto = Gemini first, OpenRouter on quota/credit errors
# gemini | openrouter = force one provider
AMITY_LLM_PROVIDER=auto

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENROUTER_API_KEY=
# Avoid openrouter/free for demos (often 20s+). Example fast route:
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# true = extra slow retry on openrouter/free after failures
AMITY_LLM_FALLBACK_FREE=false
# Cap coaching JSON size (default 220)
AMITY_LLM_MAX_TOKENS=220

# --- Voice ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Server fallback only; agent worker uses same key for lip-sync TTS
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Skip server TTS when LiveKit is set (recommended). Auto-detected if LIVEKIT_URL set.
# AMITY_SKIP_SERVER_TTS=true

# --- Beyond Presence + LiveKit (lip-sync avatar) ---
BEYOND_PRESENCE_API_KEY=
BEYOND_PRESENCE_AGENT_ID=
BEYOND_PRESENCE_AVATAR_ID=
# false = LiveKit lip-sync (recommended). true = full bey.chat iframe
BEYOND_PRESENCE_EMBED_IFRAME=false

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent worker alias (defaults to BEYOND_PRESENCE_AVATAR_ID)
BEY_AVATAR_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
