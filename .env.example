# LLM brain — use OpenRouter (free) and/or Gemini. AMITY_LLM_PROVIDER: auto | openrouter | gemini
AMITY_LLM_PROVIDER=auto
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
BEYOND_PRESENCE_API_KEY=
BEYOND_PRESENCE_AGENT_ID=
# false = Amity coach stage + ElevenLabs audio. true = full bey.chat iframe (not recommended).
BEYOND_PRESENCE_EMBED_IFRAME=false
# Optional: explicit avatar for speech-to-video (else resolved from agent or first available avatar)
BEYOND_PRESENCE_AVATAR_ID=
# LiveKit Cloud — lip-sync via LiveKit Agents + Bey plugin (run npm run agent:dev)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Bey avatar for agent worker (defaults to BEYOND_PRESENCE_AVATAR_ID)
BEY_AVATAR_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000
